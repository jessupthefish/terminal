<IfModule mod_headers.c>
  # index.html must always be revalidated so new deploys show immediately
  <Files "index.html">
    Header set Cache-Control "no-cache, must-revalidate"
  </Files>

  # hashed bundles are immutable; a new build gets new filenames
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # fonts and overlay textures keep stable names; cache for a week
  <FilesMatch "\.(ttf|woff2?|png)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
